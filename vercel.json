{
  "name": "resonance-ai",
  "version": 2,
  "builds": [
    {
      "src": "dist/index-full.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/dist/index-full.js"
    },
    {
      "src": "/admin",
      "dest": "/dist/index-full.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}